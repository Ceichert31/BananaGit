<Window
    x:Class="BananaGit.Views.DialogueViews.DiscardChangesConfirmationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BananaGit.Views.DialogueViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DiscardChangesConfirmationView"
    Width="300"
    Height="150"
    Background="{StaticResource BananaPrimary}"
    mc:Ignorable="d"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Content="Are you sure you want to reset local changes?"
            FontSize="20"
            FontWeight="Bold"
            Foreground="Black"
            />

        <Button
            Grid.Row="1"
            Grid.Column="0"
            Width="100"
            Height="35"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="GreenYellow"
            Command="{Binding DiscardLocalChangesCommand}"
            Content="Yes"
            FontSize="20"
            Style="{StaticResource GenericButton}"
            />

        <Button
            Grid.Row="1"
            Grid.Column="1"
            Width="100"
            Height="35"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="OrangeRed"
            Content="No"
            FontSize="20"
            Style="{StaticResource GenericButton}"
            />


    </Grid>
</Window>
