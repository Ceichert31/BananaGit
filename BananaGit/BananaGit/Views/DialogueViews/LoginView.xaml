<!-- 
Handles Users first log in. This is the first window a new user will see. 
This window will redirect the user to the browser so they can log into GitHub.
-->
<Window
    x:Class="BananaGit.Views.DialogueViews.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BananaGit.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BananaGit.ViewModels"
    xmlns:valueConverters="clr-namespace:BananaGit.ValueConverters"
    Title="EnterCredentialsView"
    Width="400"
    Height="300"
    d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
    Background="#FFEA78"
    Closing="Window_Closing"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Window Header -->
        <Label
            HorizontalAlignment="Center"
            Content="Log in to Github"
            FontWeight="Bold" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <!-- Status text -->
            <Label HorizontalAlignment="Center"
                   Content="{Binding DisplayText, FallbackValue=Pressing Sign in will redirect to browser.}" />

            <!-- User code text + Copy button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding CopyUserCodeCommand}"
                        Visibility="{Binding UserCode, Converter={valueConverters:StringVisibilityConverter}}">
                    <Image Source="pack://application:,,,/Assets/Clipboard.png" Width="15" Height="15" />
                </Button>
                <Label
                    Content="{Binding UserCode}" />
            </StackPanel>
        </StackPanel>

        <!-- Confirmation button -->
        <Button
            Grid.Row="2"
            Width="50"
            Height="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            Command="{Binding UpdateCredentialsCommand}"
            Content="Sign in" />
    </Grid>
</Window>