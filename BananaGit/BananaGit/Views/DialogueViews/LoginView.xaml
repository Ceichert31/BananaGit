<!-- 
Handles Users first log in. This is the first window a new user will see. 
This window will redirect the user to the browser so they can log into GitHub.
-->
<Window
    x:Class="BananaGit.Views.DialogueViews.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BananaGit.ViewModels"
    xmlns:valueConverters="clr-namespace:BananaGit.ValueConverters"
    Title="EnterCredentialsView"
    Width="400"
    Height="300"
    ResizeMode="CanMinimize"
    d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
    Background="#FFEA78"
    Closing="Window_Closing"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Window Header -->
        <StackPanel>
            <Label
                HorizontalAlignment="Center"
                Content="Welcome to BananaGit!"
                FontSize="25"
                FontWeight="Bold" />

            <Label
                HorizontalAlignment="Center"
                Content="Please sign into GitHub to continue."
                FontSize="14"
                FontWeight="DemiBold" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <!-- Status text -->
            <Label HorizontalAlignment="Center" FontSize="14"
                   Content="{Binding DisplayText, FallbackValue=Pressing Sign in will redirect to browser.}" />

            <!-- Login website URL -->
            <TextBlock HorizontalAlignment="Center" FontSize="14"
                       Visibility="{Binding UserCode, Converter={valueConverters:StringVisibilityConverter}}">
                <Hyperlink Command="{Binding OpenLoginPageCommand}" CommandParameter="{Binding LoginUrl}">
                    Login Page
                </Hyperlink>
            </TextBlock>

            <!-- User code text + Copy button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                        Command="{Binding CopyUserCodeCommand}"
                        Visibility="{Binding UserCode, Converter={valueConverters:StringVisibilityConverter}}">
                    <Image Source="pack://application:,,,/Assets/Clipboard.png" Width="20" Height="20" />
                </Button>
                <Label
                    Content="{Binding UserCode}" FontSize="14" />
            </StackPanel>
        </StackPanel>

        <!-- Confirmation button -->
        <Button
            Grid.Row="2"
            Width="75"
            Height="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Background="White"
            Command="{Binding UpdateCredentialsCommand}"
            Content="Sign in" />
    </Grid>
</Window>