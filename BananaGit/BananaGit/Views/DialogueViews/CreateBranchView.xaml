<Window
    x:Class="BananaGit.Views.DialogueViews.CreateBranchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BananaGit.Views.DialogueViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BananaGit.ViewModels.DialogueViewModels"
    Title="CreateBranchView"
    Width="300"
    Height="450"
    d:DataContext="{d:DesignInstance Type=viewmodels:CreateBranchViewModel}"
    Background="{StaticResource BananaPrimary}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.RowSpan="3"
            BorderBrush="{StaticResource BananaDark}"
            BorderThickness="3" />
        <Label
            Grid.Row="0"
            HorizontalAlignment="Center"
            Content="Create a new branch"
            FontSize="16"
            FontWeight="SemiBold" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="25" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <Label VerticalAlignment="Center" Content="Branch Name: " />
                <TextBox
                    MinWidth="150"
                    VerticalAlignment="Center"
                    Text="{Binding BranchName}"
                    TextWrapping="WrapWithOverflow" />
            </StackPanel>

            <Label
                Grid.Row="1"
                Content="Select Branch"
                FontWeight="SemiBold" />

            <ListBox
                Grid.Row="2"
                MinWidth="150"
                MinHeight="50"
                Margin="5,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                ItemsSource="{Binding LocalBranches}"
                SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                Style="{StaticResource ListBoxStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Label VerticalAlignment="Center" Content="{Binding Name}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <StackPanel Grid.Row="2" VerticalAlignment="Center">
            <TextBlock
                HorizontalAlignment="Center"
                Text="{Binding Message, FallbackValue=Placeholder text}"
                TextWrapping="WrapWithOverflow" />

            <Button
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Command="{Binding CreateBranchCommand}"
                Content="Create Branch"
                FontSize="12"
                Style="{StaticResource GenericButton}" />
        </StackPanel>

    </Grid>
</Window>